# Copy to /etc/systemd/system/rewrite-master.service
# Adjust paths and User if needed.
#
#   sudo cp deploy/rewrite-master.service.example /etc/systemd/system/rewrite-master.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now rewrite-master

[Unit]
Description=ReWrite Master (Flask + Gunicorn)
After=network.target

[Service]
Type=simple
User=rewrite
Group=rewrite
WorkingDirectory=/opt/rewrite-app
EnvironmentFile=-/opt/rewrite-app/.env
# Long timeout: Scene Builder streams can run many minutes.
ExecStart=/opt/rewrite-app/venv/bin/gunicorn \
  --bind 0.0.0.0:5002 \
  --workers 1 \
  --threads 4 \
  --timeout 7200 \
  --access-logfile - \
  --error-logfile - \
  app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
